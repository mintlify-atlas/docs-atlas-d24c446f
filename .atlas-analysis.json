  "keyFeatures": [
    "Full PPU interpreter with VMX/AltiVec SIMD support",
    "Complete SPU interpreter with 128-bit vector operations",
    "Vulkan-based RSX graphics rendering",
    "LLVM-based JIT compilation for PPU and SPU",
    "LV2 kernel syscall emulation",
    "HLE implementations of PS3 system libraries",
    "ELF/SELF/PRX loader with decryption support",
    "Cross-platform audio and input handling",
    "ISO 9660, PKG, and PARAM.SFO support"
  ],
